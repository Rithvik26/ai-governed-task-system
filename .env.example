# Copy this file to backend/.env and adjust before running.
# The application reads these via os.environ in backend/config.py.
# None of these are required — defaults work for local development.

# SQLAlchemy connection string.
# Default: SQLite file in the backend/ directory.
# For Postgres: postgresql://user:password@localhost:5432/tasktracker
DATABASE_URL=sqlite:///tasktracker.db

# Python logging verbosity for the backend.
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
